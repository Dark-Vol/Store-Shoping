  "compilerOptions": {
    "baseUrl": "./",
    "paths": {
      "@config/*": ["src/config/*"],
      "@api/*": ["src/api/*"],
      "@lib/*": ["src/lib/*"],
      "@model/*": ["src/model/*"],
      "@controller/*": ["src/controller/*"],
      "@routers/*": ["src/routers/*"]
    }
  },
  "include": ["src/**/*"]
}
